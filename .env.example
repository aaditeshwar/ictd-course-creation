# Copy to .env and fill in your keys:
#   cp .env.example .env
#
# Used by skills/generate_examples_via_api.py, skills/book_alignment_scorer.py

ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (local GPU host for paper filtering and optional alignment scoring)
OLLAMA_BASE_URL=http://100.102.70.41:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT=120

# Default backend for book_alignment_scorer.py: anthropic | ollama
ALIGNMENT_BACKEND=ollama

# Topic content extractor (skills/topic_content_extractor.py): map vs reduce phase
# Falls back to ALIGNMENT_BACKEND when unset. Common: MAP_BACKEND=ollama, REDUCE_BACKEND=anthropic
MAP_BACKEND=ollama
REDUCE_BACKEND=anthropic
